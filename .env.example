# Supabase PostgreSQL (get from Supabase Dashboard > Settings > Database > Connection string)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection for Prisma migrations (without pgbouncer)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# App
APP_PUBLIC_URL="https://your-domain.com"

# AI Configuration
# OpenRouter (primary AI provider)
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# MiniMax M2.7, OpenAI-compatible endpoint (fallback)
MINIMAX_API_KEY=""
MINIMAX_BASE_URL="https://api.minimax.io/v1"
MINIMAX_MODEL="MiniMax-M2.7"

# AI Model Chain (comma-separated, priority order)
AI_MODEL_CHAIN="OPENROUTER:openrouter/claude-3.5-sonnet,MINIMAX:MiniMax-M2.7"

# Deduplication Settings
DEDUP_ENABLED="true"
DEDUP_STRATEGY="url,hash"
DEDUP_SEMANTIC_THRESHOLD="0.85"
DEDUP_LOOKBACK_DAYS="30"

# Report Retention
DEFAULT_REPORT_RETENTION_DAYS="7"
AUTO_ARCHIVE_REPORTS="true"
AUTO_DELETE_ARCHIVED_AFTER_DAYS="90"

# Football Data
FOOTBALL_DATA_API_KEY=""
FOOTBALL_DATA_BASE_URL="https://api.football-data.org/v4"
FOOTBALL_SYNC_INTERVAL_HOURS="6"
FOOTBALL_LEAGUES="PL,LA,SA,BL1,FL1,CL,EL,TR1"

# Slack (optional)
SLACK_BOT_TOKEN=""
SLACK_CHANNEL_ID=""
SLACK_DRY_RUN="true"
