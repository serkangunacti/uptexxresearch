# Supabase PostgreSQL (get from Supabase Dashboard > Settings > Database > Connection string)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection for Prisma migrations (without pgbouncer)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# App
APP_PUBLIC_URL="https://your-domain.com"
TZ="Europe/Istanbul"

# Admin login
ADMIN_USERNAME="serkangunacti"
ADMIN_PASSWORD="change-this-password"
# Generate with: openssl rand -base64 48
SESSION_SECRET="change-this-to-a-long-random-secret-at-least-32-chars"

# MiniMax M2.7, OpenAI-compatible endpoint
MINIMAX_API_KEY=""
MINIMAX_BASE_URL="https://api.minimax.io/v1"
MINIMAX_MODEL="MiniMax-M2.7"

# Web search
TAVILY_API_KEY=""

# Scheduler fallback endpoint and GitHub Actions dispatch
CRON_SECRET="change-this-cron-secret"
GITHUB_PAT=""
GITHUB_REPO="serkangunacti/uptexxresearch"
GITHUB_WORKFLOW_REF="main"

# Slack (optional)
SLACK_BOT_TOKEN=""
SLACK_CHANNEL_ID=""
SLACK_DRY_RUN="true"
